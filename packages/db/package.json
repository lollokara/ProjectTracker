{
  "name": "@tracker/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "migrate:run": "tsx src/migrate.ts",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "bootstrap": "tsx src/bootstrap.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "dependencies": {
    "@tracker/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
